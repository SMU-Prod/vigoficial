# ============================================
# VIG PRO - Variáveis de Ambiente
# Copie para .env.local e preencha os valores
# ============================================
#
# OPS-01 SECURITY NOTE: If .env.local is ever committed to git,
# ALL secrets below must be rotated immediately:
# - ANTHROPIC_API_KEY
# - ASAAS_API_KEY
# - SUPABASE_SERVICE_ROLE_KEY
# - JWT_SECRET
# - ENCRYPTION_KEY
# - R2_SECRET_ACCESS_KEY
# - REDIS_PASSWORD
#
# Use: git rm --cached .env.local
# Then rotate credentials in all service dashboards
# ============================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Auth ---
JWT_SECRET=gerar_com_node_crypto_randomBytes_64
NEXTAUTH_URL=http://localhost:3000

# --- Redis (BullMQ) ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Resend (Email saída) ---
RESEND_API_KEY=re_...

# --- Gmail API (Email entrada) ---
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# --- Anthropic / Claude API (Parser IA + Agentes) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Modelos IA (override dos defaults) ---
AI_MODEL_FAST=claude-haiku-4-5-20251001
AI_MODEL_COMPLEX=claude-sonnet-4-6
AI_MODEL_ADVANCED=claude-sonnet-4-6

# --- Asaas (Billing) ---
ASAAS_API_KEY=$aact_...
ASAAS_WEBHOOK_SECRET=
ASAAS_SANDBOX=true

# --- Cloudflare R2 ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=vigipro-data
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com

# --- Cron Secret ---
CRON_SECRET=gerar_com_node_crypto_randomBytes_64
# IP whitelist para cron (opcional, separar por vírgula). Ex: 127.0.0.1,10.0.0.1
# CRON_ALLOWED_IPS=

# --- GPS Webhook Secret ---
# Token de autenticação para rastreador GPS (header x-gps-token)
GPS_WEBHOOK_SECRET=

# --- Sentry ---
SENTRY_DSN=

# --- Langfuse (Observabilidade LLM) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# --- Email Config ---
EMAIL_FROM=operacoes@vigiconsultoria.com
EMAIL_EQUIPE=equipe@vigiconsultoria.com

# --- URLs Governo (override dos defaults) ---
GESP_PORTAL_URL=https://www.gov.br/pf/pt-br/assuntos/seguranca-privada/sistemas
GESP_URL=https://servicos.dpf.gov.br/gesp/
GOV_BR_LOGIN_URL=https://sso.acesso.gov.br
DOU_BASE_URL=https://www.in.gov.br

# --- Modo Teste Produção ---
# GESP_DRY_RUN=true simula execução GESP sem abrir browser (tasks marcadas como DRY-RUN-*)
GESP_DRY_RUN=false
# EMAIL_REDIRECT_TO redireciona TODOS os emails para este endereço (para testes em produção)
# EMAIL_REDIRECT_TO=atendimento.smu@gmail.com

# --- Encryption ---
ENCRYPTION_KEY=gerar_com_node_crypto_randomBytes_64
