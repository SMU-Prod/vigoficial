  /**
   * Menu: Processo Bancário > Acompanhar
   */
  async acompanharProcessosBancarios(filtros?: {
    ano?: string;
    numero?: string;
    tipo?: string;
    situacao?: string;
  }): Promise<ProcessoResult> {
    if (!this.page) return { sucesso: false, erros: ["Página não inicializada"] };

    try {
      await this.screenshot("acompanhar-bancario-inicio");
      await this.navigateMenu("Processo Bancário", "Acompanhar");
      await this.waitForGespPage();

      if (filtros?.ano) await this.fillFormField("Ano", filtros.ano);
      if (filtros?.numero) await this.fillFormField("Número", filtros.numero);
      if (filtros?.tipo) await this.selectDropdown("Tipo", filtros.tipo);
      if (filtros?.situacao) await this.selectDropdown("Situação", filtros.situacao);

      const pesquisarBtn = await this.page.$('button:has-text("Pesquisar"), input[value="Pesquisar"]');
      if (pesquisarBtn) {
        await pesquisarBtn.click();
        await this.page.waitForLoadState("networkidle");
        await delay();
      }

      const tabela = await this.parseTable('table');
      await this.screenshot("acompanhar-bancario-fim");

      return {
        sucesso: true,
        mensagem: `${tabela.length} processos encontrados`,
      };
    } catch (err) {
      console.error("[GESP] Erro ao acompanhar processos bancários:", err);
      return { sucesso: false, erros: [`${err}`] };
    }
  }

