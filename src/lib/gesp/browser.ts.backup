import { firefox, type Browser, type BrowserContext, type Page } from "playwright";
import { acquireGespLock, releaseGespLock } from "./lock";
import { logger } from "@/lib/observability/logger"; // OPS-06: Structured logging
import * as path from "path";
import * as fs from "fs";
import * as os from "os";

// =============================================================================
// VIGI — GESP Browser Automation
// Baseado na documentação oficial da Polícia Federal:
// https://www.gov.br/pf/pt-br/assuntos/seguranca-privada/sistemas/gesp
//
// FLUXO DE ACESSO GESP:
// 1. Primeiro acesso: e-CNPJ obrigatório (certificado digital da empresa)
// 2. Cadastra procuração eletrônica no GESP para procurador (pessoa física)
// 3. Acessos seguintes: e-CPF do procurador (com procuração válida)
// 4. Login via Login Único GOV.BR → opção "Seu Certificado Digital"
// 5. Seleciona CNPJ da empresa (se procurador de múltiplas)
//
// NAVEGADOR COMPATÍVEL: Apenas Mozilla Firefox ESR
// URL: https://www.gov.br/pf/pt-br/assuntos/seguranca-privada/sistemas → PGDWEB
// Acesso direto: https://servicos.dpf.gov.br/gesp/
//
// TIPOS DE CERTIFICADO:
// - e-CNPJ (A1 ou A3): Para primeiro acesso e cadastro de procuração
// - e-CPF (A1 ou A3): Para procuradores com procuração cadastrada
// - A1 = arquivo .pfx/.p12 importado no Firefox
// - A3 = token USB/smartcard físico (não suportado em automação headless)
//
// IMPORTANTE: VIGI usa apenas certificados A1 (arquivo) para automação
// =============================================================================

const _GESP_PORTAL = "https://www.gov.br/pf/pt-br/assuntos/seguranca-privada/sistemas";
const GESP_URL = "https://servicos.dpf.gov.br/gesp/";
const _GOV_BR_LOGIN = "https://sso.acesso.gov.br";

const _PF_SUPORTE_EMAILS = [
  "dicof.cgcsp.dpa@pf.gov.br",
  "dpsp.cgcsp.dpa@pf.gov.br",
];

function randomDelay(): number {
  return 1500 + Math.random() * 2500;
}

async function delay(ms?: number) {
  return new Promise((r) => setTimeout(r, ms || randomDelay()));
}

type CertificadoTipo = "e-CNPJ" | "e-CPF";

interface CertificadoConfig {
  tipo: CertificadoTipo;
  r2Path: string;
  senha: string;
  cnpjEmpresa: string;
  cpfProcurador?: string;
}

interface ProcessoResult {
  sucesso: boolean;
  protocolo?: string | null;
  turmaId?: string | null;
  guiaId?: string | null;
  numeroGuia?: string | null;
  gruLinhaDigitavel?: string | null;
  registrosProcessados?: number;
  alunosImportados?: number;
  mensagem?: string;
  erros?: string[];
  printAntes?: Buffer;
  printDepois?: Buffer;
  printScreen?: Buffer;
  pendencias?: string[];
}

interface TabelaRow {
  [key: string]: string;
}

/**
 * Gerencia sessões do navegador Firefox ESR para GESP
 *
 * PRD Regra R5: Máx. 1 sessão por empresa, 3 browsers no servidor
 */
export class GespBrowser {
  private browser: Browser | null = null;
  private context: BrowserContext | null = null;
  private page: Page | null = null;
  private companyId: string;
  private sessionId: string | null = null;
  private tempProfileDir: string | null = null;

  constructor(companyId: string) {
    this.companyId = companyId;
  }

  // =========================================================================
  // ABERTURA DO BROWSER
  // =========================================================================

  /**
   * Abre Firefox ESR com certificado digital importado
   *
   * @param certificado - Configuração do certificado digital
   * @param pfxBuffer - Buffer do arquivo .pfx já baixado do R2
   */
  async open(certificado: CertificadoConfig, pfxBuffer: Buffer): Promise<void> {
    const lockResult = await acquireGespLock(this.companyId);
    if (!lockResult.acquired) {
      throw new Error(`Falha ao adquirir lock GESP: ${lockResult.reason}`);
    }
    this.sessionId = lockResult.sessionId || null;

    try {
      this.tempProfileDir = await this.createFirefoxProfile(pfxBuffer, certificado.senha);

      this.browser = await firefox.launch({
        headless: true,
        firefoxUserPrefs: {
          "security.default_personal_cert": "Select Automatically",
          "security.enterprise_roots.enabled": true,
          "security.remember_cert_checkbox_default_setting": true,
          "security.osclientcerts.autoload": true,
        },
        args: [
          `-profile`, this.tempProfileDir,
        ],
      });

      this.context = await this.browser.newContext({
        ignoreHTTPSErrors: true,
        viewport: { width: 1366, height: 768 },
        locale: "pt-BR",
        timezoneId: "America/Sao_Paulo",
        userAgent: "Mozilla/5.0 (Windows NT 10.0; Win64; x64; rv:115.0) Gecko/20100101 Firefox/115.0",
      });

      this.page = await this.context.newPage();
      this.page.setDefaultTimeout(60_000);

    } catch (err) {
      if (this.sessionId) {
        await releaseGespLock(this.sessionId);
      }
      this.cleanupTempProfile();
      throw err;
    }
  }

  // =========================================================================
  // LOGIN
  // =========================================================================

  /**
   * Executa login no GESP via Login Único GOV.BR
   *
   * @param cnpjEmpresa - CNPJ para selecionar (quando procurador de múltiplas empresas)
   */
  async login(cnpjEmpresa: string): Promise<boolean> {
    if (!this.page) throw new Error("Browser não iniciado. Chame open() primeiro.");

    try {
      await this.page.goto(GESP_URL, { waitUntil: "networkidle", timeout: 45_000 });
      await delay();

      const currentUrl = this.page.url();

      if (currentUrl.includes("acesso.gov.br") || currentUrl.includes("sso.")) {

        const certButton = await this.page.$(
          'button:has-text("Certificado Digital"), ' +
          'a:has-text("Certificado Digital"), ' +
          'button:has-text("Seu Certificado")'
        );

        if (certButton) {
          await certButton.click();
          await delay();
        }

        await this.page.waitForURL(
          (url) => url.href.includes("dpf.gov.br") || url.href.includes("gesp"),
          { timeout: 30_000 }
        );
        await delay();
      }

      // Trata seleção de empresa (if procurator de múltiplas)
      const cnpjSelector = await this.page.$(
        'select:has(option), [name*="cnpj"], #cnpj, input[placeholder*="CNPJ"]'
      );

      if (cnpjSelector) {

        const tagName = await cnpjSelector.evaluate((el: Element) => el.tagName.toLowerCase());
        if (tagName === "select") {
          const cnpjRaiz = cnpjEmpresa.replace(/\D/g, "").substring(0, 8);
          const options = await cnpjSelector.$$eval('option', (opts: HTMLOptionElement[]) =>
            opts.map((o) => ({ value: o.value, text: o.textContent || "" }))
          );
          const match = options.find((o) => o.text.includes(cnpjRaiz));
          if (match) {
            await cnpjSelector.selectOption(match.value);
          }
        } else {
          await cnpjSelector.fill(cnpjEmpresa.replace(/\D/g, ""));
        }
        await delay(800);

        const acessarBtn = await this.page.$(
          'button:has-text("Acessar"), input[value*="Acessar"], button[type="submit"]'
        );
        if (acessarBtn) {
          await acessarBtn.click();
          await this.page.waitForLoadState("networkidle");
          await delay();
        }
      }

      const isLoggedIn = await this.verifyLoggedIn();
      if (isLoggedIn) {
        await this.screenshot("login-sucesso");
        return true;
      }

      const _diagScreenshot = await this.screenshot("login-falhou");
      logger.error("Login falhou. Screenshot salvo para diagnóstico.", { url: this.page.url() }); // OPS-06
      return false;
    } catch (err) {
      logger.error("Erro durante login", err as Error); // OPS-06
      return false;
    }
  }

  /**
   * Verifica se estamos logados no painel principal do GESP
   */
  private async verifyLoggedIn(): Promise<boolean> {
    if (!this.page) return false;

    try {
      await this.page.waitForLoadState("networkidle");
      const hasMenu = await this.page.$('text="Empresa", text="Processo Autorizativo", text="Processo Punitivo"');
      const hasUserInfo = await this.page.$('.user-info, [class*="usuario"], [class*="perfil"]');
      return hasMenu !== null || hasUserInfo !== null;
    } catch {
      return false;
    }
  }

  // =========================================================================
  // NAVEGAÇÃO DE MENUS
  // =========================================================================

  /**
   * Navega em menu dropdown do GESP
   * Padrão: clica menu principal, depois sub-item
   */
  private async navigateMenu(menuText: string, subItemText: string): Promise<void> {
    if (!this.page) throw new Error("Página não inicializada");

    try {
      // Clica no menu principal
      const menuBtn = await this.page.$(`text="${menuText}"`);
      if (menuBtn) {
        await menuBtn.click();
        await delay(300);
      }

      // Clica no sub-item
      const subBtn = await this.page.$(`text="${subItemText}"`);
      if (subBtn) {
        await subBtn.click();
        await this.page.waitForLoadState("networkidle");
        await delay();
      }
    } catch (err) {
      logger.error("Erro ao navegar menu", { menuText, subItemText, error: err as Error }); // OPS-06
      throw err;
    }
  }

  /**
   * Preenche campo de formulário por rótulo (label text)
   */
  private async fillFormField(labelText: string, value: string): Promise<void> {
    if (!this.page) throw new Error("Página não inicializada");

    try {
      const input = await this.page.locator(`label:has-text("${labelText}") >> .. >> input, label:has-text("${labelText}") >> .. >> textarea`).first();
      if (input) {
        await input.fill(value);
      }
    } catch (err) {
      logger.error("Erro ao preencher campo", { labelText, error: err as Error }); // OPS-06
    }
  }

  /**
   * Seleciona opção em dropdown por label
   */
  private async selectDropdown(labelText: string, optionText: string): Promise<void> {
    if (!this.page) throw new Error("Página não inicializada");

    try {
      const select = await this.page.locator(`label:has-text("${labelText}") >> .. >> select`).first();
      if (select) {
        await select.selectOption({ label: optionText });
      }
    } catch (err) {
      logger.error("Erro ao selecionar dropdown", { labelText, error: err as Error }); // OPS-06
    }
  }

  /**
   * Clica em aba do formulário (painel esquerdo)
   */
  private async clickTab(tabName: string): Promise<void> {
    if (!this.page) throw new Error("Página não inicializada");

    try {
      const tab = await this.page.$(`text="${tabName}"`);
      if (tab) {
        await tab.click();
        await this.page.waitForLoadState("networkidle");
        await delay();
      }
    } catch (err) {
      logger.error("Erro ao clicar aba", { tabName, error: err as Error }); // OPS-06
    }
  }

  /**
   * Faz upload de arquivo em formulário JSF
   */
  private async uploadFile(buffer: Buffer, filename: string, inputSelector: string): Promise<void> {
    if (!this.page) throw new Error("Página não inicializada");

    try {
      const tmpPath = path.join(os.tmpdir(), filename);
      fs.writeFileSync(tmpPath, buffer);

      const input = await this.page.$(inputSelector);
      if (input) {
        await input.setInputFiles(tmpPath);
        await delay();
      }

      fs.unlinkSync(tmpPath);
    } catch (err) {
      logger.error("Erro ao fazer upload de arquivo", err as Error); // OPS-06
      throw err;
    }
  }

  /**
   * Extrai dados de tabela HTML
   */
  private async parseTable(selector: string = "table"): Promise<TabelaRow[]> {
    if (!this.page) return [];

    try {
      const rows = await this.page.locator(`${selector} tbody tr`).all();
      const result: TabelaRow[] = [];

      for (const row of rows) {
        const cells = await row.locator("td").allTextContents();
        if (cells.length > 0) {
          result.push({
            colunas: cells.join(" | "),
          });
        }
      }

      return result;
    } catch {
      return [];
    }
  }

  /**
   * Aguarda carregamento de página GESP
   */
  private async waitForGespPage(): Promise<void> {
    if (!this.page) throw new Error("Página não inicializada");

    try {
      await this.page.waitForLoadState("networkidle");
      await delay();
    } catch {
      logger.warn("Timeout esperando carregamento de página"); // OPS-06
    }
  }

  /**
   * Trata dialog de confirmação do GESP
   * Padrão: "Confirma [ação]?" → Sim / Não
   */
  private async handleGespConfirmation(): Promise<string | null> {
    if (!this.page) return null;

    try {
      const simBtn = await this.page.$('button:has-text("Sim"), input[value="Sim"]');
      if (simBtn) {
        await simBtn.click();
        await this.page.waitForLoadState("networkidle");
        await delay();

        const successMsg = await this.page.$('.message, .alert-success, .msg-sucesso, .info-message');
        if (successMsg) {
          const text = (await successMsg.textContent())?.trim() || "";
          const match = text.match(/N[ºo°]\s*(?:Processo|Protocolo)[:.]?\s*(\d{4}\/\d+)/i);
          if (match) return match[1];
          return text;
        }
      }
    } catch {
      // Dialog pode não ter aparecido
    }

    return null;
  }

  /**
   * Clica em botão de ação universal: EXCLUIR | VERIFICAR | ENVIAR
   */
  private async clickGespActionButton(action: "EXCLUIR" | "VERIFICAR" | "ENVIAR"): Promise<string | null> {
    if (!this.page) return null;

    try {
      await this.page.click(`button:has-text("${action}"), input[value="${action}"], a:has-text("${action}")`);
      await this.page.waitForLoadState("networkidle");
      await delay();

      return await this.handleGespConfirmation();
    } catch (err) {
      logger.error(`Erro ao clicar ${action}`, err as Error); // OPS-06
      return null;
    }
  }

  /**
   * Captura screenshot de diagnóstico
   */
  async screenshot(label: string): Promise<Buffer> {
    if (!this.page) return Buffer.alloc(0);

    try {
      const buffer = await this.page.screenshot({ fullPage: true });
      const timestamp = new Date().toISOString().replace(/[:.]/g, "-");
      const filename = `${label}-${timestamp}.png`;
      const filepath = path.join(os.tmpdir(), filename);
      fs.writeFileSync(filepath, buffer);
      return buffer;
    } catch (err) {
      console.error("[GESP] Erro ao capturar screenshot:", err);
      return Buffer.alloc(0);
    }
  }

  // =========================================================================
  // MÓDULO EMPRESA — Atualizar Dados
  // =========================================================================

  /**
   * Menu: Empresa > Atualizar Dados
   * Formulário com 3 abas: Identificação, Endereço, Dados da Autorização
   */
  async atualizarDadosEmpresa(dados: {
    nomFantasia?: string;
    email?: string;
    telefone?: string;
    celular?: string;
    fax?: string;
    logradouro?: string;
    numero?: string;
    complemento?: string;
    bairro?: string;
    uf?: string;
    municipio?: string;
    cep?: string;
  }): Promise<ProcessoResult> {
    if (!this.page) return { sucesso: false, erros: ["Página não inicializada"] };

    try {
      await this.screenshot("atualizar-dados-inicio");
      await this.navigateMenu("Empresa", "Atualizar Dados");

      // Tab: Identificação
      await this.clickTab("Identificação");
      if (dados.nomFantasia) await this.fillFormField("Nome Fantasia", dados.nomFantasia);
      if (dados.email) await this.fillFormField("E-mail", dados.email);
      if (dados.telefone) await this.fillFormField("Telefone", dados.telefone);
      if (dados.celular) await this.fillFormField("Celular", dados.celular);
      if (dados.fax) await this.fillFormField("Fax", dados.fax);

      let saveBtn = await this.page.$('button:has-text("Salvar"), input[value="Salvar"]');
      if (saveBtn) await saveBtn.click();
      await this.page.waitForLoadState("networkidle");
      await delay();

      // Tab: Endereço
      await this.clickTab("Endereço");
      if (dados.logradouro) await this.fillFormField("Logradouro", dados.logradouro);
      if (dados.numero) await this.fillFormField("Número", dados.numero);
      if (dados.complemento) await this.fillFormField("Complemento", dados.complemento);
      if (dados.bairro) await this.fillFormField("Bairro", dados.bairro);
      if (dados.uf) await this.selectDropdown("UF", dados.uf);
      if (dados.municipio) await this.selectDropdown("Município", dados.municipio);
      if (dados.cep) await this.fillFormField("CEP", dados.cep);

      saveBtn = await this.page.$('button:has-text("Salvar"), input[value="Salvar"]');
      if (saveBtn) await saveBtn.click();
      await this.page.waitForLoadState("networkidle");

      await this.screenshot("atualizar-dados-fim");
      return { sucesso: true };
    } catch (err) {
      console.error("[GESP] Erro ao atualizar dados empresa:", err);
      return { sucesso: false, erros: [`${err}`] };
    }
  }

  // =========================================================================
  // MÓDULO EMPRESA — Gerenciar Procuradores
  // =========================================================================

  /**
   * Menu: Empresa > Gerenciar Procuradores
   */
  async gerenciarProcuradores(acao: "incluir" | "listar", dados?: {
    cpf?: string;
    nome?: string;
    dataInicio?: string;
    dataFim?: string;
  }): Promise<ProcessoResult> {
    if (!this.page) return { sucesso: false, erros: ["Página não inicializada"] };

    try {
      await this.screenshot("procuradores-inicio");
      await this.navigateMenu("Empresa", "Gerenciar Procuradores");
      await this.waitForGespPage();

      if (acao === "listar") {
        const tabela = await this.parseTable('table');
        return {
          sucesso: true,
          mensagem: `${tabela.length} procuradores encontrados`,
        };
      }

      if (acao === "incluir" && dados) {
        const incluirBtn = await this.page.$('button:has-text("Incluir Procurador")');
        if (incluirBtn) {
          await incluirBtn.click();
          await this.page.waitForLoadState("networkidle");
          await delay();
        }

        if (dados.cpf) {
          const cpfInput = await this.page.$('input[name*="cpf"]');
          if (cpfInput) {
            await cpfInput.fill(dados.cpf.replace(/\D/g, ""));
            await delay();

            const buscarBtn = await this.page.$('button:has-text("Buscar")');
            if (buscarBtn) {
              await buscarBtn.click();
              await this.page.waitForLoadState("networkidle");
              await delay();
            }
          }
        }

        if (dados.dataInicio) await this.fillFormField("Data Início", dados.dataInicio);
        if (dados.dataFim) await this.fillFormField("Data Fim", dados.dataFim);

        const salvarBtn = await this.page.$('button:has-text("Salvar"), input[value="Salvar"]');
        if (salvarBtn) {
          await salvarBtn.click();
          await this.page.waitForLoadState("networkidle");
          await delay();
        }
      }

      await this.screenshot("procuradores-fim");
      return { sucesso: true };
    } catch (err) {
      console.error("[GESP] Erro ao gerenciar procuradores:", err);
      return { sucesso: false, erros: [`${err}`] };
    }
  }

  // =========================================================================
  // MÓDULO EMPRESA — Consultar GRU
  // =========================================================================

  /**
   * Menu: Empresa > Consultar GRU
   */
  async consultarGru(linhaDigitavel: string): Promise<ProcessoResult> {
    if (!this.page) return { sucesso: false, erros: ["Página não inicializada"] };

    try {
      await this.screenshot("consultar-gru-inicio");
      await this.navigateMenu("Empresa", "Consultar GRU");
      await this.waitForGespPage();

      const linhaInput = await this.page.$('input[name*="linha"], [placeholder*="Linha Digitável"]');
      if (linhaInput) {
        await linhaInput.fill(linhaDigitavel);
        await delay();
      }

      const consultarBtn = await this.page.$('button:has-text("CONSULTAR"), input[value="CONSULTAR"]');
      if (consultarBtn) {
        await consultarBtn.click();
        await this.page.waitForLoadState("networkidle");
        await delay();
      }

      const saldoInfo = await this.page.$('.saldo-info, .balance, [class*="saldo"]');
      let saldo = "";
      if (saldoInfo) {
        saldo = (await saldoInfo.textContent())?.trim() || "";
      }

      await this.screenshot("consultar-gru-fim");
      return { sucesso: true, mensagem: saldo };
    } catch (err) {
      console.error("[GESP] Erro ao consultar GRU:", err);
      return { sucesso: false, erros: [`${err}`] };
    }
  }

  // =========================================================================
  // MÓDULO PROCESSO AUTORIZATIVO
  // =========================================================================

  /**
   * Menu: Processo Autorizativo > Acompanhar
   */
  async acompanharProcessosAutorizativos(filtros?: {
    ano?: string;
    numero?: string;
    tipo?: string;
    situacao?: string;
  }): Promise<ProcessoResult> {
    if (!this.page) return { sucesso: false, erros: ["Página não inicializada"] };

    try {
      await this.screenshot("acompanhar-auth-inicio");
      await this.navigateMenu("Processo Autorizativo", "Acompanhar");
      await this.waitForGespPage();

      if (filtros?.ano) await this.fillFormField("Ano", filtros.ano);
      if (filtros?.numero) await this.fillFormField("Número Processo", filtros.numero);
      if (filtros?.tipo) await this.selectDropdown("Tipo Processo", filtros.tipo);
      if (filtros?.situacao) await this.selectDropdown("Situação Processo", filtros.situacao);

      const pesquisarBtn = await this.page.$('button:has-text("Pesquisar"), input[value="Pesquisar"]');
      if (pesquisarBtn) {
        await pesquisarBtn.click();
        await this.page.waitForLoadState("networkidle");
        await delay();
      }

      const tabela = await this.parseTable('table');
      await this.screenshot("acompanhar-auth-fim");

      return {
        sucesso: true,
        mensagem: `${tabela.length} processos encontrados`,
      };
    } catch (err) {
      console.error("[GESP] Erro ao acompanhar processos autorizativos:", err);
      return { sucesso: false, erros: [`${err}`] };
    }
  }

  /**
   * Menu: Processo Autorizativo > Solicitar Autorização de Funcionamento
   */
  async solicitarAutorizacaoFuncionamento(dados: {
    gruLinhaDigitavel?: string;
    arquivos?: Array<{ buffer: Buffer; nome: string }>;
  }): Promise<ProcessoResult> {
    if (!this.page) return { sucesso: false, erros: ["Página não inicializada"] };

    try {
      await this.screenshot("solicitar-auth-func-inicio");
      await this.navigateMenu("Processo Autorizativo", "Solicitar Autorização de Funcionamento");
      await this.waitForGespPage();

      // Tab: Guias de Recolhimento
      await this.clickTab("Guias de Recolhimento");
      if (dados.gruLinhaDigitavel) {
        await this.fillFormField("Linha Digitável", dados.gruLinhaDigitavel);
        const salvarBtn = await this.page.$('button:has-text("Salvar"), input[value="Salvar"]');
        if (salvarBtn) {
          await salvarBtn.click();
          await this.page.waitForLoadState("networkidle");
          await delay();
        }
      }

      // Tab: Documentos
      await this.clickTab("Documentos");
      if (dados.arquivos && dados.arquivos.length > 0) {
        const fileInput = await this.page.$('input[type="file"]');
        if (fileInput) {
          for (const arquivo of dados.arquivos) {
            const tmpPath = path.join(os.tmpdir(), arquivo.nome);
            fs.writeFileSync(tmpPath, arquivo.buffer);
            await fileInput.setInputFiles(tmpPath);
            await delay(500);
            fs.unlinkSync(tmpPath);
          }
        }
      }

      // Envia processo
      const protocolo = await this.clickGespActionButton("ENVIAR");

      await this.screenshot("solicitar-auth-func-fim");
      return {
        sucesso: !!protocolo,
        protocolo,
        mensagem: protocolo ? `Processo enviado: ${protocolo}` : "Falha ao enviar",
      };
    } catch (err) {
      console.error("[GESP] Erro ao solicitar autorização de funcionamento:", err);
      return { sucesso: false, erros: [`${err}`] };
    }
  }

