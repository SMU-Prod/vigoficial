   */
  async imprimirCNV(cpfVigilante: string): Promise<ProcessoResult> {
    if (!this.page) return { sucesso: false, erros: ["Página não inicializada"] };

    try {
      await this.screenshot("imprimir-cnv-inicio");
      await this.navigateMenu("CNV", "Imprimir");
      await this.waitForGespPage();

      const cpfInput = await this.page.$('input[name*="cpf"]');
      if (cpfInput) {
        await cpfInput.fill(cpfVigilante.replace(/\D/g, ""));
        const buscarBtn = await this.page.$('button:has-text("Buscar")');
        if (buscarBtn) {
          await buscarBtn.click();
          await this.page.waitForLoadState("networkidle");
          await delay(2000); // PDF pode levar mais tempo
        }
      }

      await this.screenshot("imprimir-cnv-fim");
      return { sucesso: true, mensagem: "CNV gerado para impressão" };
    } catch (err) {
      console.error("[GESP] Erro ao imprimir CNV:", err);
      return { sucesso: false, erros: [`${err}`] };
    }
  }

  // =========================================================================
  // MÓDULO IMPORTAÇÃO
  // =========================================================================

  /**
   * Menu: Importação > Importar Veículos
   */
  async importarVeiculos(xmlContent: string): Promise<ProcessoResult> {
    if (!this.page) return { sucesso: false, erros: ["Página não inicializada"] };

    try {
      await this.screenshot("importar-veiculos-inicio");
      await this.navigateMenu("Importação", "Importar Veículos");
      await this.waitForGespPage();

      const xmlBuffer = Buffer.from(xmlContent, "utf-8");
      const tmpPath = path.join(os.tmpdir(), "veiculos.xml");
      fs.writeFileSync(tmpPath, xmlBuffer);

      const fileInput = await this.page.$('input[type="file"]');
      if (fileInput) {
        await fileInput.setInputFiles(tmpPath);
        await delay();

        const enviarBtn = await this.page.$('button:has-text("Enviar"), button:has-text("Importar")');
        if (enviarBtn) {
          await enviarBtn.click();
          await this.page.waitForLoadState("networkidle");
          await delay();
        }
      }

      fs.unlinkSync(tmpPath);

      const resultMsg = await this.page.$('.result, .info-message, .msg-sucesso');
      let resultado = "";
      if (resultMsg) {
        resultado = (await resultMsg.textContent())?.trim() || "";
      }

      await this.screenshot("importar-veiculos-fim");
      return { sucesso: true, mensagem: resultado };
    } catch (err) {
      console.error("[GESP] Erro ao importar veículos:", err);
      return { sucesso: false, erros: [`${err}`] };
    }
  }

  /**
   * Menu: Importação > Importar Pessoas
   */
  async importarPessoas(xmlContent: string): Promise<ProcessoResult> {
    if (!this.page) return { sucesso: false, erros: ["Página não inicializada"] };

    try {
      await this.screenshot("importar-pessoas-inicio");
      await this.navigateMenu("Importação", "Importar Pessoas");
      await this.waitForGespPage();

      const xmlBuffer = Buffer.from(xmlContent, "utf-8");
      const tmpPath = path.join(os.tmpdir(), "pessoas.xml");
      fs.writeFileSync(tmpPath, xmlBuffer);

      const fileInput = await this.page.$('input[type="file"]');
      if (fileInput) {
        await fileInput.setInputFiles(tmpPath);
        await delay();

        const enviarBtn = await this.page.$('button:has-text("Enviar"), button:has-text("Importar")');
        if (enviarBtn) {
          await enviarBtn.click();
          await this.page.waitForLoadState("networkidle");
          await delay();
        }
      }

      fs.unlinkSync(tmpPath);

      const resultMsg = await this.page.$('.result, .info-message, .msg-sucesso');
      let resultado = "";
      if (resultMsg) {
        resultado = (await resultMsg.textContent())?.trim() || "";
      }

      await this.screenshot("importar-pessoas-fim");
      return { sucesso: true, mensagem: resultado };
    } catch (err) {
      console.error("[GESP] Erro ao importar pessoas:", err);
      return { sucesso: false, erros: [`${err}`] };
    }
  }

