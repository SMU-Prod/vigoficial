  /**
   * 9. Cria uma comunicação de evento
   */
  async criarComunicacaoEvento(dados: {
    tipoEvento: string;
    nomeEvento: string;
    armaFogo: boolean;
    duracao?: string;
    vigilantesCpfs: string[];
    local?: string;
    dataInicio: string;
    dataFim?: string;
  }): Promise<ProcessoResult> {
    if (!this.page) return { sucesso: false, erros: ["Página não inicializada"] };

    try {
      const printAntes = await this.screenshot("criar-comunicacao-evento-inicio");
      await this.navigateMenu("Evento", "Comunicar Evento");
      await this.waitForGespPage();

      await this.selectDropdown("Tipo de Evento", dados.tipoEvento);
      await this.fillFormField("Nome do Evento", dados.nomeEvento);
      await this.fillFormField("Data de Início", dados.dataInicio);
      if (dados.dataFim) {
        await this.fillFormField("Data de Fim", dados.dataFim);
      }
      if (dados.duracao) {
        await this.fillFormField("Duração", dados.duracao);
      }
      if (dados.local) {
        await this.fillFormField("Local", dados.local);
      }

      const armaFireCheckbox = await this.page.$('input[type="checkbox"][name*="arma"], label:has-text("Arma de Fogo") >> .. >> input');
      if (armaFireCheckbox && dados.armaFogo) {
        await armaFireCheckbox.check();
      }

      // Add vigilantes CPFs
      for (const cpf of dados.vigilantesCpfs) {
        await this.fillFormField("CPF do Vigilante", cpf);
        const addBtn = await this.page.$('button:has-text("Adicionar")');
        if (addBtn) {
          await addBtn.click();
          await delay();
        }
      }

      const protocolo = await this.clickGespActionButton("ENVIAR");
      const printDepois = await this.screenshot("criar-comunicacao-evento-fim");

      return {
        sucesso: !!protocolo,
        protocolo,
        mensagem: protocolo ? `Evento comunicado: ${protocolo}` : "Falha ao comunicar",
        printAntes,
        printDepois,
      };
    } catch (err) {
      console.error("[GESP] Erro ao criar comunicação de evento:", err);
      const printDepois = await this.screenshot("criar-comunicacao-evento-erro");
      return { sucesso: false, erros: [`${err}`], printAntes: await this.screenshot("error"), printDepois };
    }
  }

  /**
   * 10. Importa XML (pessoa/veiculo/aluno)
   */
  async importarXml(tipo: string, xmlContent: string): Promise<ProcessoResult> {
    if (!this.page) return { sucesso: false, erros: ["Página não inicializada"] };

    try {
      const printAntes = await this.screenshot(`importar-${tipo}-inicio`);

      const menuMap: { [key: string]: string } = {
        pessoa: "Importação",
        veiculo: "Importação",
        aluno: "Turma",
      };
      const subItemMap: { [key: string]: string } = {
        pessoa: "Importar Pessoas",
        veiculo: "Importar Veículos",
        aluno: "Importar Alunos",
      };

      await this.navigateMenu(menuMap[tipo] || "Importação", subItemMap[tipo] || "Importar Pessoas");
      await this.waitForGespPage();

      const xmlBuffer = Buffer.from(xmlContent, "utf-8");
      const tmpPath = path.join(os.tmpdir(), `${tipo}.xml`);
      fs.writeFileSync(tmpPath, xmlBuffer);

      const fileInput = await this.page.$('input[type="file"]');
      if (fileInput) {
        await fileInput.setInputFiles(tmpPath);
        await delay();

        const enviarBtn = await this.page.$('button:has-text("Enviar"), button:has-text("Importar")');
        if (enviarBtn) {
          await enviarBtn.click();
          await this.page.waitForLoadState("networkidle");
          await delay();
        }
      }

      fs.unlinkSync(tmpPath);

      const resultMsg = await this.page.$('.result, .info-message, .msg-sucesso, [class*="sucesso"]');
      let registrosProcessados = 0;
      if (resultMsg) {
        const text = (await resultMsg.textContent()) || "";
        const match = text.match(/\d+/);
        if (match) registrosProcessados = parseInt(match[0]);
      }

      const printDepois = await this.screenshot(`importar-${tipo}-fim`);

      return {
        sucesso: true,
        registrosProcessados,
        mensagem: `${registrosProcessados} registros de ${tipo} importados`,
        printAntes,
        printDepois,
      };
    } catch (err) {
      console.error(`[GESP] Erro ao importar ${tipo}:`, err);
      const printDepois = await this.screenshot(`importar-${tipo}-erro`);
      return { sucesso: false, erros: [`${err}`], printAntes: await this.screenshot("error"), printDepois };
    }
  }

  /**
   * 11. Captura snapshot da empresa (dados completos)
   */
  // eslint-disable-next-line @typescript-eslint/no-explicit-any
  async snapshotEmpresa(): Promise<ProcessoResult & { rawData: any }> {
    if (!this.page) return { sucesso: false, erros: ["Página não inicializada"], rawData: {} };

    try {
      const printAntes = await this.screenshot("snapshot-empresa-inicio");
      await this.navigateMenu("Empresa", "Dados");
      await this.waitForGespPage();

      // Parse empresa data tables
      const vigilantesTable = await this.parseTable('table:has-text("Vigilante"), table:first-of-type');
      const postosTable = await this.parseTable('table:nth-of-type(2), table:has-text("Posto")');
      const armasTable = await this.parseTable('table:nth-of-type(3), table:has-text("Arma")');

      const rawData = {
        vigilantes: vigilantesTable,
        postos: postosTable,
        armas: armasTable,
        timestamp: new Date().toISOString(),
      };

      const printDepois = await this.screenshot("snapshot-empresa-fim");

      return {
        sucesso: true,
        mensagem: `Snapshot capturado: ${vigilantesTable.length} vigilantes, ${postosTable.length} postos, ${armasTable.length} armas`,
        rawData,
        printAntes,
        printDepois,
      };
    } catch (err) {
      console.error("[GESP] Erro ao capturar snapshot da empresa:", err);
      const printDepois = await this.screenshot("snapshot-empresa-erro");
      return { sucesso: false, erros: [`${err}`], rawData: {}, printAntes: await this.screenshot("error"), printDepois };
    }
  }

  /**
   * 12. Gera GRU para pagamento de multa
   */
  async gerarGruMulta(numeroProcesso: string): Promise<ProcessoResult> {
    if (!this.page) return { sucesso: false, erros: ["Página não inicializada"] };

    try {
      const printAntes = await this.screenshot("gerar-gru-multa-inicio");
      await this.navigateMenu("Processo Punitivo", "Acompanhar");
      await this.waitForGespPage();

      const processoRow = await this.page.$(`text="${numeroProcesso}"`);
      if (processoRow) {
        await processoRow.click();
        await this.page.waitForLoadState("networkidle");
        await delay();
      }

      const gerarGruBtn = await this.page.$('button:has-text("Gerar GRU"), button:has-text("Guia de Recolhimento")');
      if (gerarGruBtn) {
        await gerarGruBtn.click();
        await this.page.waitForLoadState("networkidle");
        await delay();
      }

      const gruLinhaDiv = await this.page.$('[class*="linha"], [class*="gru"], .resultado');
      let gruLinhaDigitavel = "";
      if (gruLinhaDiv) {
        const text = await gruLinhaDiv.textContent();
        if (text) {
          const match = text.match(/\d{5}\.\d{5}\s+\d{5}\.\d{6}\s+\d{5}\.\d{6}\s+\d/);
          if (match) gruLinhaDigitavel = match[0];
        }
      }

      const printDepois = await this.screenshot("gerar-gru-multa-fim");

      return {
        sucesso: !!gruLinhaDigitavel,
        gruLinhaDigitavel,
        mensagem: gruLinhaDigitavel ? `GRU gerada: ${gruLinhaDigitavel}` : "Falha ao gerar GRU",
        printAntes,
        printDepois,
      };
    } catch (err) {
      console.error("[GESP] Erro ao gerar GRU para multa:", err);
      const printDepois = await this.screenshot("gerar-gru-multa-erro");
      return { sucesso: false, erros: [`${err}`], printAntes: await this.screenshot("error"), printDepois };
    }
  }

  /**
   * 13. Importa alunos para uma turma via XML
   */
  async importarAlunosTurma(turmaId: string, xmlContent: string): Promise<ProcessoResult> {
    if (!this.page) return { sucesso: false, erros: ["Página não inicializada"] };

    try {
      const printAntes = await this.screenshot("importar-alunos-turma-inicio");
      await this.navigateMenu("Turma", "Acompanhar");
      await this.waitForGespPage();

      const turmaRow = await this.page.$(`text="${turmaId}"`);
      if (turmaRow) {
        await turmaRow.click();
        await this.page.waitForLoadState("networkidle");
        await delay();
      }

      const importarAlunosBtn = await this.page.$('button:has-text("Importar Alunos")');
      if (importarAlunosBtn) {
        await importarAlunosBtn.click();
        await this.page.waitForLoadState("networkidle");
        await delay();
      }

      const xmlBuffer = Buffer.from(xmlContent, "utf-8");
      const tmpPath = path.join(os.tmpdir(), "alunos.xml");
      fs.writeFileSync(tmpPath, xmlBuffer);

      const fileInput = await this.page.$('input[type="file"]');
      if (fileInput) {
        await fileInput.setInputFiles(tmpPath);
        await delay();

        const enviarBtn = await this.page.$('button:has-text("Enviar")');
        if (enviarBtn) {
          await enviarBtn.click();
          await this.page.waitForLoadState("networkidle");
          await delay();
        }
      }

      fs.unlinkSync(tmpPath);

      const resultMsg = await this.page.$('[class*="sucesso"], [class*="resultado"]');
      let alunosImportados = 0;
      if (resultMsg) {
        const text = (await resultMsg.textContent()) || "";
        const match = text.match(/\d+/);
        if (match) alunosImportados = parseInt(match[0]);
      }

      const printDepois = await this.screenshot("importar-alunos-turma-fim");

      return {
        sucesso: true,
        alunosImportados,
        protocolo: `alunos-${alunosImportados}`,
        mensagem: `${alunosImportados} alunos importados para a turma`,
        printAntes,
        printDepois,
      };
    } catch (err) {
      console.error("[GESP] Erro ao importar alunos para turma:", err);
      const printDepois = await this.screenshot("importar-alunos-turma-erro");
      return { sucesso: false, erros: [`${err}`], printAntes: await this.screenshot("error"), printDepois };
    }
  }

  /**
   * 14. Adiciona um documento a um processo autorizativo
   */
  async adicionarDocumentoProcesso(processoId: string, documento: {
    nome: string;
    tipo: string;
    buffer: Buffer;
  }): Promise<ProcessoResult> {
    if (!this.page) return { sucesso: false, erros: ["Página não inicializada"] };

    try {
      const printAntes = await this.screenshot("adicionar-documento-processo-inicio");
      await this.navigateMenu("Processo Autorizativo", "Acompanhar");
      await this.waitForGespPage();

      const processoRow = await this.page.$(`text="${processoId}"`);
      if (processoRow) {
        await processoRow.click();
        await this.page.waitForLoadState("networkidle");
        await delay();
      }

      const docTab = await this.page.$('text="Documentos"');
      if (docTab) {
        await docTab.click();
        await delay();
      }

      const tmpPath = path.join(os.tmpdir(), documento.nome);
      fs.writeFileSync(tmpPath, documento.buffer);

      const fileInput = await this.page.$('input[type="file"]');
      if (fileInput) {
        await fileInput.setInputFiles(tmpPath);
        await delay(500);

        const adicionarBtn = await this.page.$('button:has-text("Adicionar"), button:has-text("Salvar")');
        if (adicionarBtn) {
          await adicionarBtn.click();
          await this.page.waitForLoadState("networkidle");
          await delay();
        }
      }

      fs.unlinkSync(tmpPath);

      const printDepois = await this.screenshot("adicionar-documento-processo-fim");

      return {
        sucesso: true,
        mensagem: `Documento ${documento.nome} adicionado ao processo`,
        printAntes,
        printDepois,
      };
    } catch (err) {
      console.error("[GESP] Erro ao adicionar documento ao processo:", err);
      const printDepois = await this.screenshot("adicionar-documento-processo-erro");
      return { sucesso: false, erros: [`${err}`], printAntes: await this.screenshot("error"), printDepois };
    }
  }

  /**
   * 15. Consulta processos punitivos
   */
  async consultarProcessosPunitivos(): Promise<ProcessoResult & { processos: TabelaRow[] }> {
    if (!this.page) return { sucesso: false, erros: ["Página não inicializada"], processos: [], printScreen: undefined };

    try {
      const printScreen = await this.screenshot("consultar-processos-punitivos");
      await this.navigateMenu("Processo Punitivo", "Acompanhar");
      await this.waitForGespPage();

      const pesquisarBtn = await this.page.$('button:has-text("Pesquisar")');
      if (pesquisarBtn) {
        await pesquisarBtn.click();
        await this.page.waitForLoadState("networkidle");
        await delay();
      }

      const processos = await this.parseTable('table');

      return {
        sucesso: true,
        processos,
        mensagem: `${processos.length} processos punitivos encontrados`,
        printScreen,
      };
    } catch (err) {
      console.error("[GESP] Erro ao consultar processos punitivos:", err);
      const printScreen = await this.screenshot("consultar-processos-punitivos-erro");
      return { sucesso: false, erros: [`${err}`], processos: [], printScreen };
    }
  }

  /**
   * 16. Cadastra um procurador (pessoa física com procuração)
   */
  async cadastrarProcurador(cpf: string, nome: string): Promise<ProcessoResult> {
    if (!this.page) return { sucesso: false, erros: ["Página não inicializada"] };

    try {
      const printAntes = await this.screenshot("cadastrar-procurador-inicio");
      await this.navigateMenu("Empresa", "Procuradores");
      await this.waitForGespPage();

      const incluirBtn = await this.page.$('button:has-text("Incluir Procurador"), button:has-text("Novo")');
      if (incluirBtn) {
        await incluirBtn.click();
        await this.page.waitForLoadState("networkidle");
        await delay();
      }

      await this.fillFormField("CPF", cpf);
      await this.fillFormField("Nome", nome);

      const salvarBtn = await this.page.$('button:has-text("Salvar")');
      if (salvarBtn) {
        await salvarBtn.click();
        await this.page.waitForLoadState("networkidle");
        await delay();
      }

      const printDepois = await this.screenshot("cadastrar-procurador-fim");

      return {
        sucesso: true,
        mensagem: `Procurador ${nome} cadastrado com sucesso`,
        printAntes,
        printDepois,
      };
    } catch (err) {
      console.error("[GESP] Erro ao cadastrar procurador:", err);
      const printDepois = await this.screenshot("cadastrar-procurador-erro");
      return { sucesso: false, erros: [`${err}`], printAntes: await this.screenshot("error"), printDepois };
    }
  }

  /**
   * 17. Cria uma guia de transporte
   */
  async criarGuiaTransporte(dados: {
    origemCidade: string;
    origemUf: string;
    destinoCidade: string;
    destinoUf: string;
    dataTransporte: string;
    responsavelNome: string;
    responsavelCpf: string;
    veiculoPlaca?: string;
  }): Promise<ProcessoResult> {
    if (!this.page) return { sucesso: false, erros: ["Página não inicializada"] };

    try {
      const printAntes = await this.screenshot("criar-guia-transporte-inicio");
      await this.navigateMenu("Guia de Transporte", "Criar");
      await this.waitForGespPage();

      await this.fillFormField("Cidade de Origem", dados.origemCidade);
      await this.selectDropdown("UF de Origem", dados.origemUf);
      await this.fillFormField("Cidade de Destino", dados.destinoCidade);
      await this.selectDropdown("UF de Destino", dados.destinoUf);
      await this.fillFormField("Data de Transporte", dados.dataTransporte);
      await this.fillFormField("Nome do Responsável", dados.responsavelNome);
      await this.fillFormField("CPF do Responsável", dados.responsavelCpf);
      if (dados.veiculoPlaca) {
        await this.fillFormField("Placa do Veículo", dados.veiculoPlaca);
      }

      const guiaId = await this.clickGespActionButton("VERIFICAR");
      const printDepois = await this.screenshot("criar-guia-transporte-fim");

      return {
        sucesso: !!guiaId,
        guiaId,
        mensagem: guiaId ? `Guia de transporte criada: ${guiaId}` : "Falha ao criar guia",
        printAntes,
        printDepois,
      };
    } catch (err) {
      console.error("[GESP] Erro ao criar guia de transporte:", err);
      const printDepois = await this.screenshot("criar-guia-transporte-erro");
      return { sucesso: false, erros: [`${err}`], printAntes: await this.screenshot("error"), printDepois };
    }
  }

  // =========================================================================
  // CERTIFICADO DIGITAL
  // =========================================================================

  /**
   * Cria perfil Firefox temporário com certificado .pfx importado
   */
  private async createFirefoxProfile(pfxBuffer: Buffer, senha: string): Promise<string> {
    const profileDir = fs.mkdtempSync(path.join(os.tmpdir(), "vigi-gesp-"));
    const pfxPath = path.join(profileDir, "certificado.pfx");

    fs.writeFileSync(pfxPath, pfxBuffer);

    const { execSync } = await import("child_process");

    try {
      execSync(`certutil -d sql:${profileDir} -N --empty-password`, {
        stdio: "pipe",
      });

      execSync(
        `pk12util -d sql:${profileDir} -i "${pfxPath}" -W "${senha}"`,
        { stdio: "pipe" }
      );

    } catch (err) {
      console.error("[GESP] Erro ao importar certificado:", err);
    }

    fs.unlinkSync(pfxPath);
    return profileDir;
  }

  /**
   * Remove perfil Firefox temporário
   */
  private cleanupTempProfile(): void {
    if (this.tempProfileDir && fs.existsSync(this.tempProfileDir)) {
      try {
        fs.rmSync(this.tempProfileDir, { recursive: true, force: true });
      } catch (err) {
        console.error(`[GESP] Erro ao remover perfil temporário: ${err}`);
      }
      this.tempProfileDir = null;
    }
  }

  // =========================================================================
  // ENCERRAMENTO
  // =========================================================================

  /**
   * Fecha browser, libera lock e limpa recursos
   */
  async close(): Promise<void> {
    try {
      if (this.sessionId) {
        await releaseGespLock(this.sessionId);
      }
    } catch (err) {
      console.error("[GESP-BROWSER] Erro ao liberar lock:", err);
    }

    try {
      if (this.context) await this.context.close();
      if (this.browser) await this.browser.close();
    } catch (err) {
      console.error("[GESP-BROWSER] Erro ao fechar browser:", err);
    }

    this.cleanupTempProfile();

    this.page = null;
    this.context = null;
    this.browser = null;

  }
}
