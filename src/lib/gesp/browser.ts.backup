  /**
   * Menu: Responder Notificação (general/punitivo)
   */
  async responderNotificacao(numeroNotificacao: string, params: {
    texto?: string;
    arquivos?: Array<{ buffer: Buffer; nome: string }>;
  }): Promise<ProcessoResult> {
    if (!this.page) return { sucesso: false, erros: ["Página não inicializada"] };

    try {
      const printAntes = await this.screenshot("responder-notificacao-inicio");
      // Navigate to the notification response page
      // This may need adjustment based on the actual menu structure
      await this.navigateMenu("Notificação", "Responder");
      await this.waitForGespPage();

      const notifRow = await this.page.$(`text="${numeroNotificacao}"`);
      if (notifRow) {
        await notifRow.click();
        await this.page.waitForLoadState("networkidle");
        await delay();
      }

      // Fill the text response
      if (params.texto) {
        const textareaInput = await this.page.$('textarea');
        if (textareaInput) {
          await textareaInput.fill(params.texto);
        }
      }

      // Handle file attachments
      if (params.arquivos && params.arquivos.length > 0) {
        const fileInput = await this.page.$('input[type="file"]');
        if (fileInput) {
          for (const arquivo of params.arquivos) {
            const tmpPath = path.join(os.tmpdir(), arquivo.nome);
            fs.writeFileSync(tmpPath, arquivo.buffer);
            await fileInput.setInputFiles(tmpPath);
            await delay();
            fs.unlinkSync(tmpPath);
          }
        }
      }

      const protocolo = await this.clickGespActionButton("ENVIAR");
      const printDepois = await this.screenshot("responder-notificacao-fim");

      return {
        sucesso: !!protocolo,
        protocolo,
        mensagem: protocolo ? `Resposta enviada: ${protocolo}` : "Falha ao enviar",
        printAntes,
        printDepois,
      };
    } catch (err) {
      console.error("[GESP] Erro ao responder notificação:", err);
      const printDepois = await this.screenshot("responder-notificacao-erro");
      return { sucesso: false, erros: [`${err}`], printAntes: await this.screenshot("error"), printDepois };
    }
  }

