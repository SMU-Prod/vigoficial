      await this.screenshot("solicitar-nova-atividade-inicio");
      await this.navigateMenu("Processo Autorizativo", "Solicitar Autorização de Nova Atividade");
      await this.waitForGespPage();

      // Marca checkboxes de atividades
      if (dados.atividades && dados.atividades.length > 0) {
        for (const atividade of dados.atividades) {
          const checkbox = await this.page.$(`input[type="checkbox"][value="${atividade}"], label:has-text("${atividade}") >> .. >> input[type="checkbox"]`);
          if (checkbox) {
            await checkbox.check();
          }
        }
        await delay();
      }

      await this.clickTab("Guias de Recolhimento");
      if (dados.gruLinhaDigitavel) {
        await this.fillFormField("Linha Digitável", dados.gruLinhaDigitavel);
      }

      const protocolo = await this.clickGespActionButton("ENVIAR");

