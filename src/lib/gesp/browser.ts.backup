  /**
   * Menu: Comunicação de Ocorrência > Comunicar Ocorrência
   * Tipos: Roubo de Arma, Furto de Arma, Extravio de Arma, etc.
   * PRAZO: 24h inicial, 10 days complementação
   */
  async comunicarOcorrencia(dados: {
    tipo: "Roubo de Arma" | "Furto de Arma" | "Extravio de Arma" | string;
    descricao?: string;
    envolvidos?: Array<{ cpf: string; tipo: string }>;
    armas?: Array<{ tipo: string; calibre: string; nroSerie: string }>;
    arquivos?: Array<{ buffer: Buffer; nome: string }>;
  }): Promise<ProcessoResult> {
    if (!this.page) return { sucesso: false, erros: ["Página não inicializada"] };

    try {
      await this.screenshot("comunicar-ocorrencia-inicio");
      await this.navigateMenu("Comunicação de Ocorrência", "Comunicar Ocorrência");
      await this.waitForGespPage();

      // Tab: Dados Básicos
      await this.clickTab("Dados Básicos");
      await this.selectDropdown("Tipo", dados.tipo);

      // Tab: Dados da Ocorrência
      await this.clickTab("Dados da Ocorrência");
      if (dados.descricao) {
        const descInput = await this.page.$('textarea');
        if (descInput) {
          await descInput.fill(dados.descricao);
        }
      }

      // Tab: Envolvidos
      await this.clickTab("Envolvidos");
      if (dados.envolvidos && dados.envolvidos.length > 0) {
        for (const envolvido of dados.envolvidos) {
          const cpfInput = await this.page.$('input[name*="cpf"]');
          if (cpfInput) {
            await cpfInput.fill(envolvido.cpf.replace(/\D/g, ""));
            const tipoSelect = await this.page.$('select[name*="tipo"]');
            if (tipoSelect) {
              await tipoSelect.selectOption({ label: envolvido.tipo });
            }
            const addBtn = await this.page.$('button:has-text("Adicionar")');
            if (addBtn) {
              await addBtn.click();
              await this.page.waitForLoadState("networkidle");
              await delay();
            }
          }
        }
      }

      const protocolo = await this.clickGespActionButton("ENVIAR");

      await this.screenshot("comunicar-ocorrencia-fim");
      return {
        sucesso: !!protocolo,
        protocolo,
        mensagem: protocolo ? `Ocorrência comunicada: ${protocolo}` : "Falha ao comunicar",
      };
    } catch (err) {
      console.error("[GESP] Erro ao comunicar ocorrência:", err);
      return { sucesso: false, erros: [`${err}`] };
    }
  }

