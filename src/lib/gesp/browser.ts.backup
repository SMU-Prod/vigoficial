  /**
   * 3. Envia um processo (VERIFICAR + ENVIAR)
   */
  async enviarProcesso(processoId: string): Promise<ProcessoResult> {
    if (!this.page) return { sucesso: false, erros: ["Página não inicializada"] };

    try {
      const printAntes = await this.screenshot("enviar-processo-inicio");
      await this.navigateMenu("Processo Autorizativo", "Acompanhar");
      await this.waitForGespPage();

      const processoRow = await this.page.$(`text="${processoId}"`);
      if (processoRow) {
        await processoRow.click();
        await this.page.waitForLoadState("networkidle");
        await delay();
      }

      // VERIFICAR
      const _verificarResult = await this.clickGespActionButton("VERIFICAR");
      await delay();

      // ENVIAR
      const protocolo = await this.clickGespActionButton("ENVIAR");
      const printDepois = await this.screenshot("enviar-processo-fim");

      return {
        sucesso: !!protocolo,
        protocolo,
        mensagem: protocolo ? `Processo enviado: ${protocolo}` : "Falha ao enviar",
        printAntes,
        printDepois,
      };
    } catch (err) {
      console.error("[GESP] Erro ao enviar processo:", err);
      const printDepois = await this.screenshot("enviar-processo-erro");
      return { sucesso: false, erros: [`${err}`], printAntes: await this.screenshot("error"), printDepois };
    }
  }

  /**
   * 4. Verifica pendências de um processo
   */
  async verificarPendencias(processoId: string): Promise<ProcessoResult> {
    if (!this.page) return { sucesso: false, erros: ["Página não inicializada"] };

    try {
      const printAntes = await this.screenshot("verificar-pendencias-inicio");
      await this.navigateMenu("Processo Autorizativo", "Acompanhar");
      await this.waitForGespPage();

      const processoRow = await this.page.$(`text="${processoId}"`);
      if (processoRow) {
        await processoRow.click();
        await this.page.waitForLoadState("networkidle");
        await delay();
      }

      const pendenciasDiv = await this.page.$('.pendencias, .alertas, [class*="pendencia"]');
      let pendencias: string[] = [];
      if (pendenciasDiv) {
        const text = await pendenciasDiv.textContent();
        if (text) {
          pendencias = text.split('\n').filter(p => p.trim().length > 0);
        }
      }

      const printDepois = await this.screenshot("verificar-pendencias-fim");

      return {
        sucesso: true,
        pendencias,
        mensagem: `${pendencias.length} pendências encontradas`,
        printAntes,
        printDepois,
      };
    } catch (err) {
      console.error("[GESP] Erro ao verificar pendências:", err);
      const printDepois = await this.screenshot("verificar-pendencias-erro");
      return { sucesso: false, erros: [`${err}`], pendencias: [], printAntes: await this.screenshot("error"), printDepois };
    }
  }

