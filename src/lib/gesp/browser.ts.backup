  /**
   * Menu: Credenciamento de Instrutores > Solicitar Credenciamento de Instrutor
   */
  async solicitarCredenciamentoInstrutor(dados: {
    cpfInstrutor: string;
    nomeInstrutor?: string;
    disciplinas?: string[];
    curriculo?: { buffer: Buffer; nome: string };
    gruLinhaDigitavel?: string;
  }): Promise<ProcessoResult> {
    if (!this.page) return { sucesso: false, erros: ["Página não inicializada"] };

    try {
      await this.screenshot("solicitar-credenciamento-inicio");
      await this.navigateMenu("Credenciamento de Instrutores", "Solicitar Credenciamento de Instrutor");
      await this.waitForGespPage();

      const cpfInput = await this.page.$('input[name*="cpf"]');
      if (cpfInput) {
        await cpfInput.fill(dados.cpfInstrutor.replace(/\D/g, ""));
        const buscarBtn = await this.page.$('button:has-text("Buscar")');
        if (buscarBtn) {
          await buscarBtn.click();
          await this.page.waitForLoadState("networkidle");
          await delay();
        }
      }

      if (dados.disciplinas && dados.disciplinas.length > 0) {
        for (const disciplina of dados.disciplinas) {
          const checkbox = await this.page.$(`input[type="checkbox"][value="${disciplina}"], label:has-text("${disciplina}") >> .. >> input`);
          if (checkbox) {
            await checkbox.check();
          }
        }
      }

      if (dados.curriculo) {
        const fileInput = await this.page.$('input[type="file"]');
        if (fileInput) {
          const tmpPath = path.join(os.tmpdir(), dados.curriculo.nome);
          fs.writeFileSync(tmpPath, dados.curriculo.buffer);
          await fileInput.setInputFiles(tmpPath);
          await delay();
          fs.unlinkSync(tmpPath);
        }
      }

      const protocolo = await this.clickGespActionButton("ENVIAR");

      await this.screenshot("solicitar-credenciamento-fim");
      return {
        sucesso: !!protocolo,
        protocolo,
        mensagem: protocolo ? `Credenciamento solicitado: ${protocolo}` : "Falha ao solicitar",
      };
    } catch (err) {
      console.error("[GESP] Erro ao solicitar credenciamento instrutor:", err);
      return { sucesso: false, erros: [`${err}`] };
    }
  }

