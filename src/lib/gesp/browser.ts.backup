      return { sucesso: false, erros: [`${err}`] };
    }
  }

  /**
   * Menu: Processo Bancário > Solicitar Plano Mudança de Endereço
   */
  async solicitarPlanoMudancaEndereco(dados: {
    numeroPlanoAnterior?: string;
    novoEndereco?: string;
    gruLinhaDigitavel?: string;
  }): Promise<ProcessoResult> {
    if (!this.page) return { sucesso: false, erros: ["Página não inicializada"] };

    try {
      await this.screenshot("plano-mudanca-endereco-inicio");
      await this.navigateMenu("Processo Bancário", "Solicitar Plano Mudança de Endereço");
      await this.waitForGespPage();

      if (dados.numeroPlanoAnterior) {
        const nrPlanoInput = await this.page.$('input[name*="numero"], input[placeholder*="Plano"]');
        if (nrPlanoInput) {
          await nrPlanoInput.fill(dados.numeroPlanoAnterior);
        }
      }

      if (dados.novoEndereco) {
        await this.fillFormField("Novo Endereço", dados.novoEndereco);
      }

      // Tab: Guias de Recolhimento
      await this.clickTab("Guias de Recolhimento");
      if (dados.gruLinhaDigitavel) {
        await this.fillFormField("Linha Digitável", dados.gruLinhaDigitavel);
      }

      const protocolo = await this.clickGespActionButton("ENVIAR");

      await this.screenshot("plano-mudanca-endereco-fim");
      return {
        sucesso: !!protocolo,
        protocolo,
        mensagem: protocolo ? `Mudança de endereço solicitada: ${protocolo}` : "Falha ao solicitar",
      };
    } catch (err) {
      console.error("[GESP] Erro ao solicitar plano mudança endereço:", err);
      return { sucesso: false, erros: [`${err}`] };
    }
  }

