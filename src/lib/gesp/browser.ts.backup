  /**
   * Menu: Processo Punitivo > Enviar Defesa
   */
  async enviarDefesaPunitivo(numeroProcesso: string, defesa: {
    fundamentacao?: string;
    arquivos?: Array<{ buffer: Buffer; nome: string }>;
  }): Promise<ProcessoResult> {
    if (!this.page) return { sucesso: false, erros: ["Página não inicializada"] };

    try {
      await this.screenshot("enviar-defesa-punitivo-inicio");
      await this.navigateMenu("Processo Punitivo", "Enviar Defesa");
      await this.waitForGespPage();

      const processoRow = await this.page.$(`text="${numeroProcesso}"`);
