  /**
   * Menu: Processo Bancário > Solicitar Plano de Segurança Nova Agência / PAB
   * Formulário com múltiplas seções (Vigilantes, Alarme, CFTV, Detector de Metais, Cofre, etc)
   */
  async solicitarPlanoSegurancaNovaAgencia(dados: {
    nomeAgencia?: string;
    enderecoAgencia?: string;
    vigilantes?: {
      qtdPostos: number;
      cnpjEmpresaSeguranca?: string;
      disposicao?: string;
    };
    alarme?: {
      tipo?: string;
      linhaExclusiva?: boolean;
      linkRedundante?: boolean;
      fonteEnergia?: string;
      recebimentoSinal?: string;
    };
    cftv?: {
      presente?: boolean;
      especificacoes?: string;
    };
    gruLinhaDigitavel?: string;
  }): Promise<ProcessoResult> {
    if (!this.page) return { sucesso: false, erros: ["Página não inicializada"] };

    try {
      await this.screenshot("plano-seguranca-nova-agencia-inicio");
      await this.navigateMenu("Processo Bancário", "Solicitar Plano de Segurança Nova Agência / PAB");
      await this.waitForGespPage();

      // Tab: Dados Básicos
      await this.clickTab("Dados Básicos");
      if (dados.nomeAgencia) {
        await this.fillFormField("Nome Agência", dados.nomeAgencia);
      }
      if (dados.enderecoAgencia) {
        await this.fillFormField("Endereço", dados.enderecoAgencia);
      }

      // Tab: Vigilantes
      await this.clickTab("Vigilantes");
      if (dados.vigilantes?.qtdPostos) {
        await this.fillFormField("Quantidade de Postos", String(dados.vigilantes.qtdPostos));
      }
      if (dados.vigilantes?.cnpjEmpresaSeguranca) {
        await this.fillFormField("CNPJ Empresa Segurança", dados.vigilantes.cnpjEmpresaSeguranca);
      }

      // Tab: Alarme
      await this.clickTab("Alarme");
      if (dados.alarme?.tipo) {
        await this.selectDropdown("Tipo Alarme", dados.alarme.tipo);
      }
      if (dados.alarme?.linhaExclusiva !== undefined) {
        const linhaCheckbox = await this.page.$('input[type="checkbox"][name*="linha"], label:has-text("Linha Exclusiva") >> .. >> input');
        if (linhaCheckbox) {
          if (dados.alarme.linhaExclusiva) {
            await linhaCheckbox.check();
          } else {
            await linhaCheckbox.uncheck();
          }
        }
      }

      // Tab: CFTV
      await this.clickTab("CFTV");
      if (dados.cftv?.presente !== undefined) {
        const cftvCheckbox = await this.page.$('input[type="checkbox"][name*="cftv"], label:has-text("CFTV") >> .. >> input');
        if (cftvCheckbox) {
          if (dados.cftv.presente) {
            await cftvCheckbox.check();
          } else {
            await cftvCheckbox.uncheck();
          }
        }
      }

      // Tab: Guias de Recolhimento
      await this.clickTab("Guias de Recolhimento");
      if (dados.gruLinhaDigitavel) {
        await this.fillFormField("Linha Digitável", dados.gruLinhaDigitavel);
      }

      const protocolo = await this.clickGespActionButton("ENVIAR");

      await this.screenshot("plano-seguranca-nova-agencia-fim");
      return {
        sucesso: !!protocolo,
        protocolo,
        mensagem: protocolo ? `Plano de segurança solicitado: ${protocolo}` : "Falha ao solicitar",
      };
    } catch (err) {
      console.error("[GESP] Erro ao solicitar plano segurança nova agência:", err);
      return { sucesso: false, erros: [`${err}`] };
    }
  }

  /**
   * Menu: Processo Bancário > Solicitar Renovação de Plano sem Alteração ou com Aumento
   */
  async solicitarRenovacaoPlanoAumento(dados: {
    numeroPlanoAnterior?: string;
    novosElementos?: {
      nome: string;
      quantidade: number;
    }[];
    gruLinhaDigitavel?: string;
  }): Promise<ProcessoResult> {
    if (!this.page) return { sucesso: false, erros: ["Página não inicializada"] };

    try {
      await this.screenshot("renovacao-plano-aumento-inicio");
      await this.navigateMenu("Processo Bancário", "Solicitar Renovação de Plano com Aumento");
      await this.waitForGespPage();

      if (dados.numeroPlanoAnterior) {
        const nrPlanoInput = await this.page.$('input[name*="numero"], input[placeholder*="Plano"]');
        if (nrPlanoInput) {
          await nrPlanoInput.fill(dados.numeroPlanoAnterior);
        }
      }

      // Adicionar novos elementos
      if (dados.novosElementos && dados.novosElementos.length > 0) {
        for (const elemento of dados.novosElementos) {
          const nomeSelect = await this.page.$('select[name*="elemento"]');
          if (nomeSelect) {
            await nomeSelect.selectOption({ label: elemento.nome });
          }
          const qtdInput = await this.page.$('input[name*="quantidade"]');
          if (qtdInput) {
            await qtdInput.fill(String(elemento.quantidade));
          }
          const adicionarBtn = await this.page.$('button:has-text("Adicionar")');
          if (adicionarBtn) {
            await adicionarBtn.click();
            await this.page.waitForLoadState("networkidle");
            await delay();
          }
        }
      }

      await this.clickTab("Guias de Recolhimento");
      if (dados.gruLinhaDigitavel) {
        await this.fillFormField("Linha Digitável", dados.gruLinhaDigitavel);
      }

      const protocolo = await this.clickGespActionButton("ENVIAR");

      await this.screenshot("renovacao-plano-aumento-fim");
      return {
        sucesso: !!protocolo,
        protocolo,
        mensagem: protocolo ? `Renovação solicitada: ${protocolo}` : "Falha ao solicitar",
      };
    } catch (err) {
      console.error("[GESP] Erro ao solicitar renovação plano aumento:", err);
      return { sucesso: false, erros: [`${err}`] };
    }
  }

