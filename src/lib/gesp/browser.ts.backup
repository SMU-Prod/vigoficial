  /**
   * Menu: Turma > Cadastrar Turma
   */
  async cadastrarTurma(dados: {
    tipoCurso: "Formação" | "Reciclagem" | "Extensão";
    gruLinhaDigitavel?: string;
    permitirExcedentes?: boolean;
  }): Promise<ProcessoResult> {
    if (!this.page) return { sucesso: false, erros: ["Página não inicializada"] };

    try {
      await this.screenshot("cadastrar-turma-inicio");
      await this.navigateMenu("Turma", "Cadastrar Turma");
      await this.waitForGespPage();

      // Tab: Dados Básicos
      await this.clickTab("Dados Básicos");
      await this.selectDropdown("Tipo de Curso", dados.tipoCurso);
      await delay();

      // Tab: Guias de Recolhimento
      await this.clickTab("Guias de Recolhimento");
      if (dados.gruLinhaDigitavel) {
        await this.fillFormField("Linha Digitável", dados.gruLinhaDigitavel);
        const salvarBtn = await this.page.$('button:has-text("Salvar"), input[value="Salvar"]');
        if (salvarBtn) {
          await salvarBtn.click();
          await this.page.waitForLoadState("networkidle");
          await delay();
        }
      }

      // Tab: Alunos - Configurar limite
      await this.clickTab("Alunos");
      if (dados.permitirExcedentes) {
        const checkbox = await this.page.$('input[type="checkbox"][name*="excedente"], label:has-text("Permitir Excedentes") >> .. >> input');
        if (checkbox) {
          await checkbox.check();
        }
      }

      const protocolo = await this.clickGespActionButton("ENVIAR");

      await this.screenshot("cadastrar-turma-fim");
      return {
        sucesso: !!protocolo,
        protocolo,
        mensagem: protocolo ? `Turma criada: ${protocolo}` : "Falha ao criar turma",
      };
    } catch (err) {
      console.error("[GESP] Erro ao cadastrar turma:", err);
      return { sucesso: false, erros: [`${err}`] };
    }
  }

