  /**
   * Menu: Turma > Definir Disciplinas
   */
  async definirDisciplinasTurma(turmaId: string, disciplinas: string[]): Promise<ProcessoResult> {
    if (!this.page) return { sucesso: false, erros: ["Página não inicializada"] };

    try {
      const printAntes = await this.screenshot("definir-disciplinas-turma-inicio");
      await this.navigateMenu("Turma", "Acompanhar");
      await this.waitForGespPage();

      const turmaRow = await this.page.$(`text="${turmaId}"`);
      if (turmaRow) {
        await turmaRow.click();
        await this.page.waitForLoadState("networkidle");
        await delay();
      }

      const disciplinasBtn = await this.page.$('button:has-text("Disciplinas"), button:has-text("Definir Disciplinas")');
      if (disciplinasBtn) {
        await disciplinasBtn.click();
        await this.page.waitForLoadState("networkidle");
        await delay();
      }

      // Select disciplinas checkboxes
      if (disciplinas && disciplinas.length > 0) {
        for (const disciplina of disciplinas) {
          const checkbox = await this.page.$(`input[type="checkbox"][value="${disciplina}"], label:has-text("${disciplina}") >> .. >> input[type="checkbox"]`);
          if (checkbox) {
            await checkbox.check();
          }
        }
      }

      const protocolo = await this.clickGespActionButton("ENVIAR");
      const printDepois = await this.screenshot("definir-disciplinas-turma-fim");

      return {
        sucesso: !!protocolo,
        protocolo,
        mensagem: protocolo ? `Disciplinas definidas: ${disciplinas.join(", ")}` : "Falha ao definir disciplinas",
        printAntes,
        printDepois,
      };
    } catch (err) {
      console.error("[GESP] Erro ao definir disciplinas turma:", err);
      const printDepois = await this.screenshot("definir-disciplinas-turma-erro");
      return { sucesso: false, erros: [`${err}`], printAntes: await this.screenshot("error"), printDepois };
    }
  }

